  "description": "AI-native programming framework where agents define primitives and LLMs generate execution plans",
  "main": "dist/src/index.js",
  "types": "dist/src/index.d.ts",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest",
    "test:run": "vitest run",
    "lint": "eslint src",
    "clean": "rm -rf dist"
  },
  "keywords": [
    "ai",
    "llm",
    "agent",
    "symbolic",
    "planning",
    "execution"
  ],
  "author": "",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/OpenSymbolicAI/core-ts.git"
  },
  "bugs": {
    "url": "https://github.com/OpenSymbolicAI/core-ts/issues"
  },
  "homepage": "https://github.com/OpenSymbolicAI/core-ts#readme",
  "dependencies": {
    "dotenv": "^17.3.1",
    "reflect-metadata": "^0.2.2",
    "typescript": "^5.7.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@types/node": "^22.0.0",
    "eslint": "^9.39.2",
    "typescript-eslint": "^8.54.0",
    "vitest": "^2.1.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "import": "./dist/src/index.js"
    }
